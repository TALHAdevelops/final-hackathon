// MaintainIQ — Prisma schema
// AI-powered QR asset-maintenance platform (SMIT Final Hackathon, Track A)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum UserRole {
  ADMIN
  TECHNICIAN
  SUPERVISOR
  REPORTER
}

enum AssetStatus {
  OPERATIONAL
  ISSUE_REPORTED
  UNDER_INSPECTION
  UNDER_MAINTENANCE
  OUT_OF_SERVICE
  RETIRED
}

enum IssueStatus {
  REPORTED
  ASSIGNED
  INSPECTION_STARTED
  MAINTENANCE_IN_PROGRESS
  WAITING_FOR_PARTS
  RESOLVED
  CLOSED
  REOPENED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EvidenceType {
  IMAGE
  VIDEO
}

enum HistoryAction {
  ASSET_CREATED
  ASSET_UPDATED
  ISSUE_REPORTED
  ISSUE_ASSIGNED
  STATUS_CHANGED
  MAINTENANCE_RECORDED
  ISSUE_RESOLVED
  ISSUE_REOPENED
  ISSUE_CLOSED
  ASSET_RETIRED
}

// ---------- Models ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(TECHNICIAN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedIssues     Issue[]              @relation("AssignedTechnician")
  maintenanceRecords MaintenanceRecord[]
  historyEvents      AssetHistory[]
}

model Asset {
  id              String      @id @default(cuid())
  // Public-facing unique code (e.g. AST-0001) shown on labels
  code            String      @unique
  // Stable id encoded in the QR / public URL — never changes on rename
  publicId        String      @unique @default(cuid())
  name            String
  category        String
  location        String
  condition       String?
  status          AssetStatus @default(OPERATIONAL)
  description     String?
  lastServiceDate DateTime?
  nextServiceDate DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  issues  Issue[]
  history AssetHistory[]

  @@index([status])
  @@index([category])
}

model Issue {
  id                   String        @id @default(cuid())
  // Human-readable unique issue number (e.g. ISS-000123)
  number               String        @unique
  assetId              String
  title                String
  description          String
  category             String?
  priority             IssuePriority @default(MEDIUM)
  status               IssueStatus   @default(REPORTED)
  reporterName         String?
  reporterContact      String?
  assignedTechnicianId String?
  // Raw structured AI triage output (title/category/priority/causes/checks)
  aiSuggested          Json?
  // Whether the reporter edited the AI suggestions before saving
  aiEdited             Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  asset              Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignedTechnician User?               @relation("AssignedTechnician", fields: [assignedTechnicianId], references: [id])
  maintenanceRecords MaintenanceRecord[]
  evidence           Evidence[]

  @@index([assetId])
  @@index([status])
  @@index([priority])
  @@index([assignedTechnicianId])
}

model MaintenanceRecord {
  id            String    @id @default(cuid())
  issueId       String
  technicianId  String
  // Required — enforces "no resolve without a maintenance note"
  notes         String
  partsReplaced Json?
  // Non-negative enforced in service layer
  cost          Decimal?  @db.Decimal(12, 2)
  timeSpent     Int? // minutes
  finalCondition String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  issue      Issue      @relation(fields: [issueId], references: [id], onDelete: Cascade)
  technician User       @relation(fields: [technicianId], references: [id])
  evidence   Evidence[]

  @@index([issueId])
  @@index([technicianId])
}

model Evidence {
  id                  String       @id @default(cuid())
  url                 String
  type                EvidenceType @default(IMAGE)
  issueId             String?
  maintenanceRecordId String?
  uploadedAt          DateTime     @default(now())

  issue             Issue?             @relation(fields: [issueId], references: [id], onDelete: Cascade)
  maintenanceRecord MaintenanceRecord? @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([maintenanceRecordId])
}

// Append-only timeline — no update/delete methods exposed in the service layer
model AssetHistory {
  id             String        @id @default(cuid())
  assetId        String
  // Nullable: public actions (e.g. anonymous issue report) have no actor
  actorId        String?
  action         HistoryAction
  detail         Json?
  relatedIssueId String?
  createdAt      DateTime      @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id])

  @@index([assetId])
  @@index([createdAt])
}
