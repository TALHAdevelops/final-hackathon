{
  "info": {
    "name": "MaintainIQ API",
    "description": "AI-powered QR Maintenance & Asset History Platform. Set {{baseUrl}} (default http://localhost:4000/api). Run 'Auth > Login (admin)' first — it stores {{token}} automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "token", "value": "" },
    { "key": "assetId", "value": "" },
    { "key": "publicId", "value": "" },
    { "key": "issueId", "value": "" },
    { "key": "technicianId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) { pm.collectionVariables.set('token', res.accessToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@maintainiq.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        },
        {
          "name": "Login (technician)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["const res = pm.response.json();", "if (res.accessToken) pm.collectionVariables.set('token', res.accessToken);", "if (res.user) pm.collectionVariables.set('technicianId', res.user.id);"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"tech@maintainiq.com\",\n  \"password\": \"Tech@123\"\n}" }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"New Tech\",\n  \"email\": \"newtech@example.com\",\n  \"password\": \"Pass@123\"\n}" }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List technicians",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users?role=TECHNICIAN", "host": ["{{baseUrl}}"], "path": ["users"], "query": [{ "key": "role", "value": "TECHNICIAN" }] }
          }
        }
      ]
    },
    {
      "name": "Assets",
      "item": [
        {
          "name": "Create asset",
          "event": [
            { "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if (r.id) pm.collectionVariables.set('assetId', r.id);", "if (r.publicId) pm.collectionVariables.set('publicId', r.publicId);"] } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/assets", "host": ["{{baseUrl}}"], "path": ["assets"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Classroom Projector 01\",\n  \"category\": \"Projector\",\n  \"location\": \"Room A-101\"\n}" }
          }
        },
        {
          "name": "List assets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/assets?search=&status=&page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["assets"], "query": [{ "key": "search", "value": "" }, { "key": "status", "value": "" }, { "key": "page", "value": "1" }, { "key": "limit", "value": "20" }] }
          }
        },
        {
          "name": "Get asset",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/assets/{{assetId}}", "host": ["{{baseUrl}}"], "path": ["assets", "{{assetId}}"] } }
        },
        {
          "name": "Asset history",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/assets/{{assetId}}/history", "host": ["{{baseUrl}}"], "path": ["assets", "{{assetId}}", "history"] } }
        },
        {
          "name": "Update asset",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/assets/{{assetId}}", "host": ["{{baseUrl}}"], "path": ["assets", "{{assetId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"location\": \"Room B-202\"\n}" }
          }
        },
        {
          "name": "Retire asset",
          "request": { "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/assets/{{assetId}}/retire", "host": ["{{baseUrl}}"], "path": ["assets", "{{assetId}}", "retire"] } }
        }
      ]
    },
    {
      "name": "QR",
      "item": [
        { "name": "QR data", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/assets/{{assetId}}/qr", "host": ["{{baseUrl}}"], "path": ["assets", "{{assetId}}", "qr"] } } },
        { "name": "QR PNG", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/assets/{{assetId}}/qr.png", "host": ["{{baseUrl}}"], "path": ["assets", "{{assetId}}", "qr.png"] } } },
        { "name": "Print label", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/assets/{{assetId}}/label", "host": ["{{baseUrl}}"], "path": ["assets", "{{assetId}}", "label"] } } }
      ]
    },
    {
      "name": "Public (no auth)",
      "item": [
        { "name": "Get public asset", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/public/assets/{{publicId}}", "host": ["{{baseUrl}}"], "path": ["public", "assets", "{{publicId}}"] } } },
        {
          "name": "AI Triage",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/public/assets/{{publicId}}/triage", "host": ["{{baseUrl}}"], "path": ["public", "assets", "{{publicId}}", "triage"] },
            "body": { "mode": "raw", "raw": "{\n  \"complaint\": \"The projector display is flickering and sometimes does not detect HDMI\"\n}" }
          }
        },
        {
          "name": "Report issue",
          "event": [ { "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if (r.id) pm.collectionVariables.set('issueId', r.id);"] } } ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/public/assets/{{publicId}}/issues", "host": ["{{baseUrl}}"], "path": ["public", "assets", "{{publicId}}", "issues"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"HDMI flicker and no signal\",\n  \"description\": \"Display flickering and sometimes no HDMI detect\",\n  \"priority\": \"HIGH\",\n  \"reporterName\": \"Ali\"\n}" }
          }
        },
        { "name": "Public issue status", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/public/issues/ISS-000001", "host": ["{{baseUrl}}"], "path": ["public", "issues", "ISS-000001"] } } }
      ]
    },
    {
      "name": "Issues workflow",
      "item": [
        { "name": "List issues", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/issues?status=&priority=&page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["issues"], "query": [{ "key": "status", "value": "" }, { "key": "priority", "value": "" }, { "key": "page", "value": "1" }, { "key": "limit", "value": "20" }] } } },
        { "name": "Get issue", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/issues/{{issueId}}", "host": ["{{baseUrl}}"], "path": ["issues", "{{issueId}}"] } } },
        {
          "name": "Assign",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/issues/{{issueId}}/assign", "host": ["{{baseUrl}}"], "path": ["issues", "{{issueId}}", "assign"] },
            "body": { "mode": "raw", "raw": "{\n  \"technicianId\": \"{{technicianId}}\"\n}" }
          }
        },
        {
          "name": "Start inspection",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/issues/{{issueId}}/status", "host": ["{{baseUrl}}"], "path": ["issues", "{{issueId}}", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"INSPECTION_STARTED\"\n}" }
          }
        },
        {
          "name": "Record maintenance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/issues/{{issueId}}/maintenance", "host": ["{{baseUrl}}"], "path": ["issues", "{{issueId}}", "maintenance"] },
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Replaced damaged HDMI cable\",\n  \"partsReplaced\": \"HDMI cable\",\n  \"cost\": 1200,\n  \"timeSpent\": 30,\n  \"finalCondition\": \"Good\"\n}" }
          }
        },
        { "name": "Resolve", "request": { "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/issues/{{issueId}}/resolve", "host": ["{{baseUrl}}"], "path": ["issues", "{{issueId}}", "resolve"] } } },
        { "name": "Close", "request": { "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/issues/{{issueId}}/close", "host": ["{{baseUrl}}"], "path": ["issues", "{{issueId}}", "close"] } } },
        { "name": "Reopen", "request": { "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/issues/{{issueId}}/reopen", "host": ["{{baseUrl}}"], "path": ["issues", "{{issueId}}", "reopen"] } } }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        { "name": "Summary", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/dashboard/summary", "host": ["{{baseUrl}}"], "path": ["dashboard", "summary"] } } }
      ]
    }
  ]
}
